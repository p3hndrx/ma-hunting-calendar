# Google Calendar IDs for each calendar.
# Find each in Google Calendar > Settings > your calendar > Integrate Calendar > Calendar ID.
# Example: abc123xyz@group.calendar.google.com
HUNTING_CALENDAR_ID=your-hunting-calendar@group.calendar.google.com
FURBEARER_CALENDAR_ID=your-furbearer-calendar@group.calendar.google.com
MIGRATORY_CALENDAR_ID=your-migratory-calendar@group.calendar.google.com

# Full path to your service account JSON key file.
# setup.sh will set this automatically to <repo-dir>/service-account-key.json.
GOOGLE_APPLICATION_CREDENTIALS=/home/your-username/projects/ma-hunting-calendar/service-account-key.json

# Email notifications (optional).
# Generate an App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFY_EMAIL=you@gmail.com
